  <widget type="label" version="2.0.0">
    <name>text #411</name>
    <text>171 : FES PS1 CL FL SRF</text>
    <x>57</x>
    <y>460</y>
    <width>110</width>
    <height>10</height>
    <font>
      <font family="Liberation Sans" style="REGULAR" size="10.0">
      </font>
